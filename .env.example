# La Chona – Environment Variables
# Copy this file to .env and fill in your credentials

# ─── Slack Credentials ───────────────────────────────────────
# From: api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN_CULTURE=xoxb-your-bot-token-here

# From: api.slack.com/apps → Your App → Settings → Socket Mode
SLACK_APP_TOKEN_CULTURE=xapp-your-app-token-here

# From: api.slack.com/apps → Your App → Basic Information → App Credentials
SLACK_SIGNING_SECRET_CULTURE=your-signing-secret-here
